<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="@string/settings_cat_lock">

        <ListPreference
            app:key="pref_lock_timeout"
            app:title="@string/settings_lock_timeout"
            app:entries="@array/lock_timeout_entries"
            app:entryValues="@array/lock_timeout_values"
            app:persistent="false"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            app:key="pref_biometric"
            app:title="@string/settings_biometric"
            app:summary="@string/settings_biometric_summary"
            app:persistent="false" />

        <Preference
            app:key="pref_lock_now"
            app:title="@string/settings_lock_now"
            app:summary="@string/settings_lock_now_summary" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/settings_cat_security">

        <Preference
            app:key="pref_change_passphrase"
            app:title="@string/settings_change_passphrase" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/settings_cat_organization">

        <Preference
            app:key="pref_manage_tags"
            app:title="@string/settings_manage_tags" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/settings_cat_reminders">

        <SwitchPreferenceCompat
            app:key="pref_daily_reminder"
            app:title="@string/settings_daily_reminder"
            app:summary="@string/settings_daily_reminder_summary"
            app:persistent="false" />

        <Preference
            app:key="pref_reminder_time"
            app:title="@string/settings_reminder_time"
            app:persistent="false" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/settings_cat_data">

        <Preference
            app:key="pref_backup_export"
            app:title="@string/settings_backup_export"
            app:summary="@string/settings_backup_export_summary" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/settings_cat_about">

        <Preference
            app:key="pref_version"
            app:title="@string/settings_version"
            app:selectable="false" />

        <Preference
            app:key="pref_offline"
            app:title="@string/settings_offline"
            app:summary="@string/settings_offline_summary"
            app:selectable="false" />
    </PreferenceCategory>
</PreferenceScreen>